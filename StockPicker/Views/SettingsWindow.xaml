<Window x:Class="StockPicker.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:StockPicker.Converters"
        Title="Settings"
        Width="560" Height="480"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <conv:IndexUniverseConverter x:Key="IndexDisplayConverter" />
        <Style x:Key="SettingsLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="SettingsNote" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#888" />
            <Setter Property="FontStyle" Value="Italic" />
            <Setter Property="Margin" Value="0,2,0,10" />
        </Style>
        <Style x:Key="TabContent" TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="Padding" Value="16,14,16,14" />
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- Auto-save notice -->
        <Border DockPanel.Dock="Top" Background="#F5F5F5" BorderBrush="#DDD"
                BorderThickness="0,0,0,1" Padding="16,8">
            <TextBlock Text="All changes are saved automatically."
                       FontSize="11" Foreground="#888" FontStyle="Italic" />
        </Border>

        <!-- Close button -->
        <Border DockPanel.Dock="Bottom" Padding="16,10" BorderBrush="#DDD" BorderThickness="0,1,0,0">
            <Button Content="Close" Click="Close_Click"
                    Padding="24,6" HorizontalAlignment="Right"
                    IsDefault="True" IsCancel="True" />
        </Border>

        <!-- Tab pages -->
        <TabControl Margin="8,8,8,4">

            <!-- Data Sources -->
            <TabItem Header="Data Sources">
                <ScrollViewer Style="{StaticResource TabContent}">
                    <StackPanel>
                        <TextBlock Text="Enable or disable data providers and enter API keys."
                                   Style="{StaticResource SettingsNote}" />

                        <ItemsControl ItemsSource="{Binding DataSources}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="10" BorderBrush="#DDD"
                                            BorderThickness="1" CornerRadius="4">
                                        <StackPanel>
                                            <CheckBox IsChecked="{Binding IsEnabled}" FontWeight="SemiBold">
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                            </CheckBox>
                                            <TextBlock Text="{Binding FreeInfo}"
                                                       FontSize="11" Foreground="#888" FontStyle="Italic"
                                                       Margin="20,2,0,4" />
                                            <StackPanel Orientation="Horizontal" Margin="20,0,0,0"
                                                        Visibility="{Binding RequiresApiKey, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="API Key:" VerticalAlignment="Center"
                                                           Margin="0,0,6,0" FontSize="12" />
                                                <TextBox Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                                                         Width="340" FontSize="12" VerticalContentAlignment="Center"
                                                         ToolTip="{Binding ApiKeyUrl, StringFormat='Get a key at: {0}'}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Yahoo Finance requires no key. For others, enter your API key above."
                                   Style="{StaticResource SettingsNote}" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Scanning -->
            <TabItem Header="Scanning">
                <ScrollViewer Style="{StaticResource TabContent}">
                    <StackPanel>
                        <TextBlock Text="Configure what the scanner looks at and how often it refreshes."
                                   Style="{StaticResource SettingsNote}" />

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Stock index:" Style="{StaticResource SettingsLabel}" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding IndexOptions}"
                                      SelectedItem="{Binding SelectedIndex}"
                                      ToolTip="Which index to scan. Dow30/S&amp;P100/NASDAQ100 use built-in lists; S&amp;P 500 is fetched live.">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource IndexDisplayConverter}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>
                        <TextBlock Text="{Binding SelectedIndexDescription}" Style="{StaticResource SettingsNote}" />

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Scan limit:" Style="{StaticResource SettingsLabel}" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding UniverseSizeOptions}"
                                      SelectedItem="{Binding UniverseSize}"
                                      ToolTip="Maximum stocks to scan from the selected index." />
                        </Grid>
                        <TextBlock Text="Takes effect on the next scan / refresh." Style="{StaticResource SettingsNote}" />

                        <!-- Daily Picks universe cap -->
                        <TextBlock Text="Daily Picks" FontWeight="SemiBold" Margin="0,12,0,4" />
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Picks universe cap:" Style="{StaticResource SettingsLabel}" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding DayPickUniverseSizeOptions}"
                                      SelectedItem="{Binding DayPickUniverseSize}"
                                      ToolTip="Max stocks the Daily Picks engine evaluates. 0 = all stocks from the last scan." />
                        </Grid>
                        <TextBlock Text="0 = use all stocks from the last scan. Lower values are faster but may miss setups." Style="{StaticResource SettingsNote}" />

                        <TextBlock Text="Scan" FontWeight="SemiBold" Margin="0,12,0,4" />
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Auto-refresh interval:" Style="{StaticResource SettingsLabel}" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding RefreshIntervalOptions}"
                                      SelectedItem="{Binding RefreshIntervalMinutes}"
                                      ToolTip="How often to re-fetch data during market hours." />
                            <TextBlock Grid.Column="2" Text=" min" VerticalAlignment="Center" Margin="6,0,0,0" />
                        </Grid>
                        <TextBlock Text="Only fires when the market is open (9:30&#x2013;16:00 ET, Mon&#x2013;Fri)." Style="{StaticResource SettingsNote}" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Analysis -->
            <TabItem Header="Analysis">
                <ScrollViewer Style="{StaticResource TabContent}">
                    <StackPanel>
                        <TextBlock Text="Set return targets used to classify Recommendations as Buy / Hold / Avoid."
                                   Style="{StaticResource SettingsNote}" />

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Target profit / week:" Style="{StaticResource SettingsLabel}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="&#x25BC;" Width="26" Height="24" Padding="0"
                                        Command="{Binding DecrementWeeklyCommand}"
                                        ToolTip="Decrease by 0.10%" />
                                <TextBox Width="60" TextAlignment="Center" Height="24" VerticalContentAlignment="Center"
                                         Text="{Binding TargetProfitMarginPercent, UpdateSourceTrigger=LostFocus, StringFormat=F2}"
                                         ToolTip="Minimum weekly return % to classify a pick as a Buy."
                                         Margin="4,0" />
                                <Button Content="&#x25B2;" Width="26" Height="24" Padding="0"
                                        Command="{Binding IncrementWeeklyCommand}"
                                        ToolTip="Increase by 0.10%" />
                                <TextBlock Text=" %" VerticalAlignment="Center" Margin="6,0,0,0" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Target profit / month:" Style="{StaticResource SettingsLabel}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="&#x25BC;" Width="26" Height="24" Padding="0"
                                        Command="{Binding DecrementMonthlyCommand}"
                                        ToolTip="Decrease by 0.10%" />
                                <TextBox Width="60" TextAlignment="Center" Height="24" VerticalContentAlignment="Center"
                                         Text="{Binding TargetMonthlyProfitPercent, UpdateSourceTrigger=LostFocus, StringFormat=F2}"
                                         ToolTip="Equivalent monthly return % (compound of weekly). Changing this updates the weekly figure."
                                         Margin="4,0" />
                                <Button Content="&#x25B2;" Width="26" Height="24" Padding="0"
                                        Command="{Binding IncrementMonthlyCommand}"
                                        ToolTip="Increase by 0.10%" />
                                <TextBlock Text=" %" VerticalAlignment="Center" Margin="6,0,0,0" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Weekly and monthly targets stay in sync via compound interest. Recommendations update instantly."
                                   Style="{StaticResource SettingsNote}" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Columns -->
            <TabItem Header="Columns">
                <ScrollViewer Style="{StaticResource TabContent}">
                    <StackPanel>
                        <TextBlock Text="Toggle which columns appear in the Recommendations grid."
                                   Style="{StaticResource SettingsNote}" />
                        <ItemsControl ItemsSource="{Binding AllColumns}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Header}"
                                              IsChecked="{Binding IsVisible}"
                                              Margin="0,4,20,4" VerticalAlignment="Center"
                                              MinWidth="100" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
