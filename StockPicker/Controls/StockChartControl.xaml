<UserControl x:Class="StockPicker.Controls.StockChartControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="120" MinWidth="200">
    <Grid>
        <!-- Loading overlay -->
        <TextBlock x:Name="LoadingText"
                   Text="Loading chart…"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="#888" FontStyle="Italic" FontSize="11"
                   Visibility="Collapsed" />
        <!-- Chart canvas — drawn in code-behind -->
        <Canvas x:Name="ChartCanvas" ClipToBounds="True"
                Background="#1C1E2A"
                SizeChanged="ChartCanvas_SizeChanged" />
    </Grid>
</UserControl>
