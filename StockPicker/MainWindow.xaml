<Window x:Class="StockPicker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:StockPicker.ViewModels"
        xmlns:conv="clr-namespace:StockPicker.Converters"
        xmlns:ctrl="clr-namespace:StockPicker.Controls"
        xmlns:m="clr-namespace:StockPicker.Models;assembly=StockPicker.Core"
        Title="{Binding SelectedStrategy.Name, StringFormat='Stock Picker — {0}', FallbackValue='Stock Picker'}"
        Height="720" Width="1400"
        MinWidth="600" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        SizeChanged="Window_SizeChanged">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <conv:LayoutModeToVisibilityConverter x:Key="LayoutModeToVisibility" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />

        <!-- Proxy that forwards the DataContext into DataGridColumn children,
             which don't participate in the visual tree. -->
        <conv:BindingProxy x:Key="VMProxy" Data="{Binding}" />

        <!-- ── Shared styles ──────────────────────────────────────────────── -->
        <Style TargetType="GroupBox">
            <Setter Property="Padding" Value="4" />
            <Setter Property="Margin"  Value="0" />
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>
        <Style x:Key="ColPickerCheck" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,2,12,2" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- ── Scrollable-header TabControl ─────────────────────────────────
             Default WPF TabControls wrap overflowing tab headers onto extra
             rows (and otherwise clip them) with no way to scroll. When the
             Details panel is expanded it squeezes the tab column, so the tab
             strip can overflow. This template hosts the header TabPanel inside
             a horizontal ScrollViewer, giving a draggable left↔right scrollbar
             that keeps every tab reachable. -->
        <Style x:Key="ScrollableHeaderTabControl" TargetType="TabControl">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local"
                              SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Scrollable tab-header strip -->
                            <ScrollViewer Grid.Row="0"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled"
                                          Focusable="False" Padding="0">
                                <TabPanel IsItemsHost="True"
                                          Panel.ZIndex="1"
                                          KeyboardNavigation.TabIndex="1" />
                            </ScrollViewer>

                            <!-- Selected tab content -->
                            <Border Grid.Row="1"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                                  ContentSource="SelectedContent"
                                                  Margin="{TemplateBinding Padding}"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Row color style (shared by both layouts) ─────────────────── -->
        <!-- Shared context menu for any DataGrid row that has a Symbol property -->
        <ContextMenu x:Key="RowContextMenu">
            <MenuItem Header="Open in Yahoo Finance"
                      Command="{Binding Data.OpenInBrowserCommand, Source={StaticResource VMProxy}}"
                      CommandParameter="{Binding PlacementTarget.DataContext.Symbol,
                                         RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
            <Separator />
            <MenuItem Header="Ask AI about this stock">
                <MenuItem Header="🤖  Ask Claude"
                          Command="{Binding Data.AskAICommand, Source={StaticResource VMProxy}}"
                          CommandParameter="claude" />
                <MenuItem Header="✦  Ask Gemini"
                          Command="{Binding Data.AskAICommand, Source={StaticResource VMProxy}}"
                          CommandParameter="gemini" />
                <MenuItem Header="⊕  Ask Copilot"
                          Command="{Binding Data.AskAICommand, Source={StaticResource VMProxy}}"
                          CommandParameter="copilot" />
            </MenuItem>
        </ContextMenu>

        <Style x:Key="RecRowStyle" TargetType="DataGridRow">
            <Setter Property="ContextMenu" Value="{StaticResource RowContextMenu}" />
            <!-- Tooltip: company name, sector, and key signal on hover -->
            <Setter Property="ToolTip">
                <Setter.Value>
                    <ToolTip MaxWidth="380">
                        <StackPanel>
                            <TextBlock Text="{Binding CompanyName}" FontWeight="Bold" FontSize="13" />
                            <TextBlock Text="{Binding Sector, StringFormat='Sector: {0}'}"
                                       Foreground="#666" Margin="0,2,0,6" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding LastPrice,    StringFormat='Price:  ${0:F2}'}" />
                                    <TextBlock Text="{Binding DayChangePctDisplay, StringFormat='Change: {0}'}" />
                                    <TextBlock Text="{Binding RSI14,        StringFormat='RSI14:  {0:F1}'}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding MarketCapDisplay, StringFormat='Mkt Cap: {0}'}" />
                                    <TextBlock Text="{Binding PERatio,      StringFormat='P/E:     {0:F1}'}" />
                                    <TextBlock Text="{Binding Beta,          StringFormat='Beta:    {0:F2}'}" />
                                </StackPanel>
                            </Grid>
                            <Separator Margin="0,6" />
                            <TextBlock Text="{Binding Reasoning}" TextWrapping="Wrap" FontStyle="Italic" Foreground="#444" />
                        </StackPanel>
                    </ToolTip>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Action}" Value="StrongBuy">
                    <Setter Property="Background" Value="#A5D6A7" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Action}" Value="Buy">
                    <Setter Property="Background" Value="#E8F5E9" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Action}" Value="Sell">
                    <Setter Property="Background" Value="#FFCDD2" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Action}" Value="StrongSell">
                    <Setter Property="Background" Value="#EF9A9A" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- =========================================================== -->
        <!-- Details templates — selected automatically by the runtime     -->
        <!-- type of ActiveSelection. Each template binds ONLY its own      -->
        <!-- type's properties, so no "property not found" binding errors   -->
        <!-- are raised regardless of which kind of item is selected.       -->
        <!-- =========================================================== -->
        <DataTemplate DataType="{x:Type m:Recommendation}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8">
                    <TextBlock Text="{Binding Symbol, FallbackValue='(select an item)'}"
                               FontSize="20" FontWeight="Bold" />
                    <TextBlock Text="{Binding CompanyName, FallbackValue=''}"
                               FontSize="14" Foreground="#444" Margin="0,2,0,0" />
                    <TextBlock Text="{Binding Sector, StringFormat='Sector: {0}', FallbackValue=''}"
                               Foreground="#666" FontStyle="Italic" Margin="0,2,0,0" />

                    <TextBlock Text="{Binding Action, StringFormat='Action: {0}', FallbackValue=''}"
                               Margin="0,10,0,0" />
                    <TextBlock Text="{Binding Confidence, StringFormat='Confidence: {0:P1}', FallbackValue=''}"
                               Margin="0,4,0,0" />

                    <!-- Live price block -->
                    <Separator Margin="0,10" />
                    <TextBlock Text="Live Market Data" FontWeight="SemiBold" />
                    <WrapPanel Margin="0,4,0,0">
                        <TextBlock Text="{Binding DayOpen,            StringFormat='Open: ${0:F2}  ',      FallbackValue=''}" />
                        <TextBlock Text="{Binding LastPrice,          StringFormat='Price: ${0:F2}  ',     FallbackValue=''}" />
                        <TextBlock Text="{Binding DayChangeDisplay,   StringFormat='{}Change: {0}  ',      FallbackValue=''}" />
                        <TextBlock Text="{Binding DayChangePctDisplay,StringFormat='{}({0})  ',            FallbackValue=''}" />
                    </WrapPanel>
                    <WrapPanel Margin="0,2,0,0">
                        <TextBlock Text="{Binding VolumeDisplay,      StringFormat='Vol: {0}  ',           FallbackValue=''}" />
                        <TextBlock Text="{Binding AvgVolumeDisplay,   StringFormat='Avg Vol: {0}  ',       FallbackValue=''}" />
                        <TextBlock Text="{Binding MarketCapDisplay,   StringFormat='Mkt Cap: {0}  ',       FallbackValue=''}" />
                    </WrapPanel>
                    <WrapPanel Margin="0,2,0,0">
                        <TextBlock Text="{Binding PERatio,            StringFormat='P/E: {0:F1}  ',        FallbackValue=''}" />
                        <TextBlock Text="{Binding ForwardPE,          StringFormat='Fwd P/E: {0:F1}  ',    FallbackValue=''}" />
                        <TextBlock Text="{Binding EPS,                StringFormat='EPS: ${0:F2}  ',       FallbackValue=''}" />
                        <TextBlock Text="{Binding PriceToBook,        StringFormat='P/B: {0:F2}  ',        FallbackValue=''}" />
                    </WrapPanel>
                    <WrapPanel Margin="0,2,0,0">
                        <TextBlock Text="{Binding Week52High,         StringFormat='52W H: ${0:F2}  ',     FallbackValue=''}" />
                        <TextBlock Text="{Binding Week52Low,          StringFormat='52W L: ${0:F2}  ',     FallbackValue=''}" />
                        <TextBlock Text="{Binding Beta,               StringFormat='Beta: {0:F2}  ',       FallbackValue=''}" />
                        <TextBlock Text="{Binding DividendYieldPct,   StringFormat='Div: {0:F2}%  ',       FallbackValue=''}" />
                        <TextBlock Text="{Binding ShortRatio,         StringFormat='Short Ratio: {0:F1}  ',FallbackValue=''}" />
                        <TextBlock Text="{Binding DataContext.DetailsIVDisplay,
                                             RelativeSource={RelativeSource AncestorType=Window},
                                             StringFormat='IV: {0}  '}" />
                        <TextBlock Text="{Binding DataContext.DetailsThetaDisplay,
                                             RelativeSource={RelativeSource AncestorType=Window},
                                             StringFormat='Theta: {0}  '}" />
                    </WrapPanel>

                    <!-- Technical indicators -->
                    <Separator Margin="0,10" />
                    <TextBlock Text="Technical Indicators" FontWeight="SemiBold" />
                    <WrapPanel Margin="0,4,0,0">
                        <TextBlock Text="{Binding RSI14,             StringFormat='RSI14: {0:F1}  ',       FallbackValue=''}" />
                        <TextBlock Text="{Binding WeekReturnDisplay, StringFormat='{}Week Ret: {0}  ',     FallbackValue=''}" />
                        <TextBlock Text="{Binding SMA20,             StringFormat='SMA20: ${0:F2}  ',      FallbackValue=''}" />
                        <TextBlock Text="{Binding SMA50,             StringFormat='SMA50: ${0:F2}  ',      FallbackValue=''}" />
                        <TextBlock Text="{Binding VolumeTrend,       StringFormat='Vol Trend: {0:F2}×  ',  FallbackValue=''}" />
                    </WrapPanel>

                    <!-- Trade dates -->
                    <Separator Margin="0,10" />
                    <TextBlock Text="Trade Dates" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding BuyDate,       StringFormat='Buy:  {0:ddd, MMM d yyyy}',        FallbackValue=''}" Margin="0,4,0,0" />
                    <TextBlock Text="{Binding SellDate,      StringFormat='Sell: {0:ddd, MMM d yyyy}',        FallbackValue=''}" Margin="0,2,0,0" />
                    <TextBlock Text="{Binding EntryDate,     StringFormat='Entry: {0:ddd, MMM d yyyy}',       FallbackValue=''}" Margin="0,4,0,0" />
                    <TextBlock Text="{Binding PlannedSellDate,StringFormat='Planned exit: {0:ddd, MMM d yyyy}',FallbackValue=''}" Margin="0,2,0,0" />
                    <TextBlock Text="{Binding HoldingPeriod, StringFormat='Holding period: {0}'}"             Margin="0,4,0,0" Foreground="#666" />

                    <!-- Target price -->
                    <Separator Margin="0,10" />
                    <TextBlock Text="{Binding TargetPrice, StringFormat='Target price: ${0:F2}', FallbackValue=''}" />
                    <TextBlock Text="{Binding TargetHitProbabilityDisplay, StringFormat='Target hit probability: {0}', FallbackValue=''}"
                               Margin="0,2,0,0" />
                    <WrapPanel Margin="0,2,0,0">
                        <TextBlock Text="{Binding ExpectedDaysToTargetDisplay, StringFormat='Avg days to hit: {0}  ', FallbackValue=''}" />
                        <TextBlock Text="{Binding MedianDaysToTargetDisplay,   StringFormat='Median: {0}  ',         FallbackValue=''}" />
                        <TextBlock Text="{Binding TargetHitSampleSizeDisplay,  StringFormat='Analogs: {0}',          FallbackValue=''}" />
                    </WrapPanel>
                    <TextBlock Text="{Binding EntryPrice,  StringFormat='Entry price: ${0:F2}',  FallbackValue=''}" Margin="0,2,0,0" />
                    <TextBlock Text="{Binding ShareCount,  StringFormat='Shares: {0}',           FallbackValue=''}" Margin="0,2,0,0" />
                    <TextBlock Text="{Binding GeneratedAt, StringFormat='Generated: {0:g}',      FallbackValue=''}" Margin="0,4,0,0" Foreground="#666" />

                    <!-- Reasoning -->
                    <Separator Margin="0,10" />
                    <TextBlock Text="Reasoning / Notes" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Reasoning, FallbackValue=''}" TextWrapping="Wrap" Margin="0,4,0,0" />
                    <TextBlock Text="{Binding Notes,     FallbackValue=''}" TextWrapping="Wrap" Margin="0,4,0,0" />

                    <!-- Ask AI -->
                    <Separator Margin="0,10" />
                    <TextBlock Text="Ask AI" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock Text="Builds a detailed analysis prompt from this stock's data, copies it to your clipboard, and opens the chosen AI."
                               TextWrapping="Wrap" Foreground="#666" FontSize="10" Margin="0,0,0,8" />
                    <WrapPanel>
                        <Button Content="🤖 Claude"
                                Command="{Binding DataContext.AskAICommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="claude"
                                Padding="10,5" Margin="0,0,6,4"
                                ToolTip="Copy prompt and open Claude.ai" />
                        <Button Content="✦ Gemini"
                                Command="{Binding DataContext.AskAICommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="gemini"
                                Padding="10,5" Margin="0,0,6,4"
                                ToolTip="Copy prompt and open Google Gemini" />
                        <Button Content="⊕ Copilot"
                                Command="{Binding DataContext.AskAICommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="copilot"
                                Padding="10,5" Margin="0,0,0,4"
                                ToolTip="Open Microsoft Copilot with prompt pre-filled" />
                    </WrapPanel>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <!-- Shared "Ask AI" footer reused by the per-type detail templates below.
             Commands bind to the Window's MainViewModel, so it works for any item type. -->
        <DataTemplate x:Key="AskAIFooter">
            <StackPanel>
                <Separator Margin="0,10" />
                <TextBlock Text="Ask AI" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBlock Text="Builds a detailed analysis prompt from this stock's data, copies it to your clipboard, and opens the chosen AI."
                           TextWrapping="Wrap" Foreground="#666" FontSize="10" Margin="0,0,0,8" />
                <WrapPanel>
                    <Button Content="🤖 Claude"
                            Command="{Binding DataContext.AskAICommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="claude"
                            Padding="10,5" Margin="0,0,6,4"
                            ToolTip="Copy prompt and open Claude.ai" />
                    <Button Content="✦ Gemini"
                            Command="{Binding DataContext.AskAICommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="gemini"
                            Padding="10,5" Margin="0,0,6,4"
                            ToolTip="Copy prompt and open Google Gemini" />
                    <Button Content="⊕ Copilot"
                            Command="{Binding DataContext.AskAICommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="copilot"
                            Padding="10,5" Margin="0,0,0,4"
                            ToolTip="Open Microsoft Copilot with prompt pre-filled" />
                </WrapPanel>
            </StackPanel>
        </DataTemplate>

        <!-- Details — Daily Pick (intraday) -->
        <DataTemplate DataType="{x:Type m:DayPick}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8">
                    <TextBlock Text="{Binding Symbol}" FontSize="20" FontWeight="Bold" />
                    <TextBlock Text="{Binding CompanyName}" FontSize="14" Foreground="#444" Margin="0,2,0,0" />
                    <TextBlock Text="{Binding Sector, StringFormat='Sector: {0}'}"
                               Foreground="#666" FontStyle="Italic" Margin="0,2,0,0" />

                    <TextBlock Text="{Binding DirectionDisplay, StringFormat='Direction: {0}'}" Margin="0,10,0,0" />
                    <TextBlock Text="{Binding ScoreDisplay, StringFormat='Intraday score: {0}'}" Margin="0,4,0,0" />

                    <Separator Margin="0,10" />
                    <TextBlock Text="Live Market Data" FontWeight="SemiBold" />
                    <WrapPanel Margin="0,4,0,0">
                        <TextBlock Text="{Binding LastPrice,           StringFormat='Price: ${0:F2}  ', FallbackValue=''}" />
                        <TextBlock Text="{Binding DayChangePctDisplay,  StringFormat='Change: {0}  ',    FallbackValue=''}" />
                    </WrapPanel>

                    <Separator Margin="0,10" />
                    <TextBlock Text="Intraday Signals" FontWeight="SemiBold" />
                    <WrapPanel Margin="0,4,0,0">
                        <TextBlock Text="{Binding RSI14,             StringFormat='RSI14: {0:F1}  ', FallbackValue=''}" />
                        <TextBlock Text="{Binding VolumeRatioDisplay, StringFormat='Vol Ratio: {0}  '}" />
                        <TextBlock Text="{Binding GapPctDisplay,      StringFormat='Gap: {0}  '}" />
                        <TextBlock Text="{Binding AtrPctDisplay,      StringFormat='ATR: {0}  '}" />
                    </WrapPanel>

                    <Separator Margin="0,10" />
                    <TextBlock Text="Trade Levels" FontWeight="SemiBold" />
                    <WrapPanel Margin="0,4,0,0">
                        <TextBlock Text="{Binding EntryPrice,        StringFormat='Entry: ${0:F2}  ',  FallbackValue=''}" />
                        <TextBlock Text="{Binding StopLoss,          StringFormat='Stop: ${0:F2}  ',   FallbackValue=''}" />
                        <TextBlock Text="{Binding Target,            StringFormat='Target: ${0:F2}  ', FallbackValue=''}" />
                        <TextBlock Text="{Binding RiskRewardDisplay, StringFormat='R:R {0}  '}" />
                    </WrapPanel>

                    <Separator Margin="0,10" />
                    <TextBlock Text="Signals" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding TriggerReason}" TextWrapping="Wrap" Margin="0,4,0,0" />
                    <TextBlock Text="{Binding GeneratedAt, StringFormat='Generated: {0:g}'}"
                               Margin="0,4,0,0" Foreground="#666" />

                    <ContentControl ContentTemplate="{StaticResource AskAIFooter}" Content="{Binding}" />
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <!-- Details — Earnings pick -->
        <DataTemplate DataType="{x:Type m:EarningsPick}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8">
                    <TextBlock Text="{Binding Symbol}" FontSize="20" FontWeight="Bold" />
                    <TextBlock Text="{Binding CompanyName}" FontSize="14" Foreground="#444" Margin="0,2,0,0" />
                    <TextBlock Text="{Binding Sector, StringFormat='Sector: {0}'}"
                               Foreground="#666" FontStyle="Italic" Margin="0,2,0,0" />

                    <Separator Margin="0,10" />
                    <TextBlock Text="Earnings" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding EarningsDateDisplay, StringFormat='Next earnings: {0}'}" Margin="0,4,0,0" />

                    <Separator Margin="0,10" />
                    <TextBlock Text="Live Market Data" FontWeight="SemiBold" />
                    <WrapPanel Margin="0,4,0,0">
                        <TextBlock Text="{Binding LastPrice,          StringFormat='Price: ${0:F2}  ', FallbackValue=''}" />
                        <TextBlock Text="{Binding DayChangePctDisplay, StringFormat='Change: {0}  ',    FallbackValue=''}" />
                        <TextBlock Text="{Binding ImpliedVolatility,   StringFormat='IV: {0:P1}  ',     FallbackValue=''}" />
                    </WrapPanel>

                    <Separator Margin="0,10" />
                    <TextBlock Text="Signals" FontWeight="SemiBold" />
                    <WrapPanel Margin="0,4,0,0">
                        <TextBlock Text="{Binding ExpectedMoveDisplay, StringFormat='Expected move: {0}  '}" />
                        <TextBlock Text="{Binding ScoreDisplay,        StringFormat='Score: {0}  '}" />
                        <TextBlock Text="{Binding MomentumDisplay,     StringFormat='Momentum: {0}  '}" />
                        <TextBlock Text="{Binding FlagDisplay,         StringFormat='Flag: {0}  '}" />
                    </WrapPanel>

                    <StackPanel Visibility="{Binding MarginApplied, Converter={StaticResource BoolToVisibility}}">
                        <Separator Margin="0,10" />
                        <TextBlock Text="Margin" FontWeight="SemiBold" />
                        <WrapPanel Margin="0,4,0,0">
                            <TextBlock Text="{Binding LeverageDisplay,        StringFormat='Leverage: {0}  '}" />
                            <TextBlock Text="{Binding InterestCostDisplay,     StringFormat='Interest: {0}  '}" />
                            <TextBlock Text="{Binding NetMarginReturnDisplay,  StringFormat='Net return: {0}  '}" />
                        </WrapPanel>
                    </StackPanel>

                    <Separator Margin="0,10" />
                    <TextBlock Text="Signals / Notes" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding TriggerReason}" TextWrapping="Wrap" Margin="0,4,0,0" />
                    <TextBlock Text="{Binding GeneratedAt, StringFormat='Generated: {0:g}'}"
                               Margin="0,4,0,0" Foreground="#666" />

                    <ContentControl ContentTemplate="{StaticResource AskAIFooter}" Content="{Binding}" />
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <!-- Details — Held position -->
        <DataTemplate DataType="{x:Type m:HeldPosition}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8">
                    <TextBlock Text="{Binding Symbol}" FontSize="20" FontWeight="Bold" />
                    <TextBlock Text="{Binding CompanyName}" FontSize="14" Foreground="#444" Margin="0,2,0,0" />
                    <TextBlock Text="{Binding SourceTag, StringFormat='Source: {0}'}"
                               Foreground="#666" FontStyle="Italic" Margin="0,2,0,0" />

                    <Separator Margin="0,10" />
                    <TextBlock Text="Position" FontWeight="SemiBold" />
                    <WrapPanel Margin="0,4,0,0">
                        <TextBlock Text="{Binding EntryPrice, StringFormat='Entry: ${0:F2}  '}" />
                        <TextBlock Text="{Binding ShareCount, StringFormat='Shares: {0}  '}" />
                        <TextBlock Text="{Binding EntryDate,  StringFormat='Entered: {0:MMM d, yyyy}  '}" />
                    </WrapPanel>

                    <Separator Margin="0,10" />
                    <TextBlock Text="Live Market Data" FontWeight="SemiBold" />
                    <WrapPanel Margin="0,4,0,0">
                        <TextBlock Text="{Binding LastPrice,                StringFormat='Price: ${0:F2}  ', FallbackValue=''}" />
                        <TextBlock Text="{Binding CurrentValueDisplay,      StringFormat='Value: {0}  '}" />
                        <TextBlock Text="{Binding UnrealizedGainDisplay,    StringFormat='Gain: {0}  '}" />
                        <TextBlock Text="{Binding UnrealizedGainPctDisplay, StringFormat='({0})  '}" />
                    </WrapPanel>

                    <Separator Margin="0,10" />
                    <TextBlock Text="Plan" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding PlannedSellDate, StringFormat='Planned exit: {0:ddd, MMM d yyyy}', FallbackValue=''}" Margin="0,4,0,0" />
                    <TextBlock Text="{Binding HoldingPeriod,   StringFormat='Holding period: {0}'}" Margin="0,4,0,0" Foreground="#666" />

                    <Separator Margin="0,10" />
                    <TextBlock Text="Notes" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Notes}" TextWrapping="Wrap" Margin="0,4,0,0" />

                    <ContentControl ContentTemplate="{StaticResource AskAIFooter}" Content="{Binding}" />
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <!-- Chart range toggle style -->
        <Style x:Key="ChartRangeBtn" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#999" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="#555" BorderThickness="1" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3D52" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#888" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Row 0: Header + strategy    -->
            <RowDefinition Height="Auto" />  <!-- Row 1: Market index bar     -->
            <RowDefinition Height="*"    />  <!-- Row 2: Body                 -->
            <RowDefinition Height="Auto" />  <!-- Row 3: Status bar           -->
        </Grid.RowDefinitions>

        <!-- =========================================================== -->
        <!-- Row 0: Header — title, strategy selector, settings button    -->
        <!-- =========================================================== -->
        <DockPanel Grid.Row="0" Margin="0,0,0,8" LastChildFill="True">

            <!-- Settings + Details toggle (right) -->
            <Button Content="⚙  Settings"
                    Click="Settings_Click"
                    Padding="10,5"
                    DockPanel.Dock="Right"
                    VerticalAlignment="Center"
                    ToolTip="Open application settings" />
            <ToggleButton Content="Details ▐"
                          IsChecked="{Binding ShowDetails}"
                          Padding="10,5"
                          DockPanel.Dock="Right"
                          VerticalAlignment="Center"
                          Margin="0,0,6,0"
                          ToolTip="Show or hide the Details panel" />

            <!-- Strategy selector + description (fills all remaining space) -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Strategy:" Style="{StaticResource LabelStyle}" />

                <ComboBox ItemsSource="{Binding Strategies}"
                          SelectedItem="{Binding SelectedStrategy}"
                          MinWidth="180" Margin="0,0,12,0"
                          ToolTip="{Binding SelectedStrategy.Description}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"
                                       ToolTip="{Binding Description}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Full description of the active strategy (truncated; full text via tooltip) -->
                <TextBlock Text="{Binding SelectedStrategy.Description}"
                           ToolTip="{Binding SelectedStrategy.Description}"
                           Foreground="#666" FontStyle="Italic"
                           VerticalAlignment="Center"
                           MaxWidth="700"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DockPanel>

        <!-- =========================================================== -->
        <!-- Row 1: Market index bar — DOW / S&P 500 / NASDAQ / Russell   -->
        <!-- =========================================================== -->
        <Border Grid.Row="1"
                Background="#EEF2F7" BorderBrush="#C5CAE9"
                BorderThickness="0,1,0,1" Padding="8,5" Margin="0,0,0,4">
            <DockPanel LastChildFill="False">
                <!-- Updated timestamp — docked to the right -->
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding MarketIndexStatus}"
                           Foreground="#999" FontSize="10"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0" />

                <!-- Index cards — horizontal list -->
                <ItemsControl ItemsSource="{Binding MarketIndices}"
                              DockPanel.Dock="Left">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                <!-- Index name label -->
                                <TextBlock Text="{Binding Name}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="#556"
                                           Margin="0,0,7,0"
                                           VerticalAlignment="Center" />
                                <!-- Current level -->
                                <TextBlock Text="{Binding PriceDisplay}"
                                           FontSize="12" FontWeight="Bold"
                                           Foreground="#111"
                                           Margin="0,0,6,0"
                                           VerticalAlignment="Center" />
                                <!-- Change (colored green / red) -->
                                <TextBlock FontSize="11" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text"       Value="{Binding ChangeDisplay}" />
                                            <Setter Property="Foreground" Value="#388E3C" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPositive}" Value="False">
                                                    <Setter Property="Foreground" Value="#D32F2F" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <!-- =========================================================== -->
        <!-- Row 2: Body — Full (side-by-side) vs Compact (stacked)        -->
        <!-- (Column visibility is in ⚙ Settings → Column Visibility)     -->
        <!-- =========================================================== -->

        <!-- FULL LAYOUT -->
        <Grid x:Name="FullBodyGrid"
              Grid.Row="2"
              Visibility="{Binding LayoutMode,
                          Converter={StaticResource LayoutModeToVisibility},
                          ConverterParameter=Full}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" MinWidth="320" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="2*" MinWidth="0" />
            </Grid.ColumnDefinitions>

            <TabControl Grid.Column="0" Style="{StaticResource ScrollableHeaderTabControl}">
                <!-- ===== Recommendations tab ===== -->
                <TabItem Header="Recommendations">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="4">
                            <Button Content="Add to Watch" Command="{Binding AddToWatchCommand}"
                                    Padding="10,4" Margin="0,0,6,0" />
                            <Button Content="Mark as Held" Command="{Binding AddToHeldCommand}"
                                    Padding="10,4" />
                        </StackPanel>

                        <!-- Filter bar -->
                        <Border DockPanel.Dock="Top" Background="#F5F5F5" BorderBrush="#DDD"
                                BorderThickness="0,0,0,1" Padding="6,5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <!-- Search box -->
                                <Border Grid.Column="0" BorderBrush="#CCC" BorderThickness="1"
                                        CornerRadius="3" Background="White" Margin="0,0,8,0">
                                    <Grid>
                                        <TextBlock Text="&#xE721;  Search symbol or company…"
                                                   Foreground="#AAA" FontSize="11" Margin="6,4"
                                                   IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 BorderThickness="0" Background="Transparent"
                                                 VerticalContentAlignment="Center" Padding="6,3"
                                                 FontSize="12" />
                                    </Grid>
                                </Border>
                                <!-- Buy Only toggle -->
                                <ToggleButton Grid.Column="1"
                                              Content="Buy Only"
                                              IsChecked="{Binding BuyOnlyFilter}"
                                              Padding="10,4"
                                              ToolTip="Show only Buy-rated recommendations" />
                            </Grid>
                        </Border>

                        <DataGrid x:Name="FullRecsGrid"
                                  ItemsSource="{Binding RecommendationsView}"
                                  SelectedItem="{Binding SelectedRecommendation}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  AlternatingRowBackground="#F7F7F7"
                                  HorizontalScrollBarVisibility="Auto"
                                  EnableColumnVirtualization="True"
                                  CanUserReorderColumns="True"
                                  RowStyle="{StaticResource RecRowStyle}"
                                  Sorting="FullRecsGrid_Sorting"
                                  ColumnDisplayIndexChanged="FullRecsGrid_ColumnDisplayIndexChanged">

                            <DataGrid.Columns>

                                <!-- Symbol + Company Name (always visible) -->
                                <DataGridTemplateColumn Header="Symbol" Width="110" SortMemberPath="Symbol">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="2,1">
                                                <TextBlock Text="{Binding Symbol}"
                                                           FontWeight="SemiBold" FontSize="12" />
                                                <TextBlock Text="{Binding CompanyName}"
                                                           FontSize="9" Foreground="#666"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Source — which data source(s) contributed to this recommendation -->
                                <DataGridTextColumn Header="Source"
                                    Binding="{Binding SourceDisplay}"
                                    Width="90"
                                    Visibility="{Binding Data.ColSource.IsVisible,
                                                         Source={StaticResource VMProxy},
                                                         Converter={StaticResource BoolToVisibility}}" />

                                <!-- Action (always visible) — SortMemberPath routes header-click through
                                     ActionSortOrder (int) so the enum sorts StrongBuy→StrongSell,
                                     not alphabetically. -->
                                <DataGridTextColumn Header="Action" Binding="{Binding Action}"
                                                    SortMemberPath="ActionSortOrder" Width="88" />

                                <!-- Toggleable — price & daily move -->
                                <DataGridTextColumn Header="Price"
                                    Binding="{Binding LastPrice, StringFormat={}{0:F2}}"
                                    Width="68"
                                    Visibility="{Binding Data.ColPrice.IsVisible,
                                                         Source={StaticResource VMProxy},
                                                         Converter={StaticResource BoolToVisibility}}" />
                                <DataGridTextColumn Header="Change $"
                                    Binding="{Binding DayChangeDisplay}"
                                    Width="74"
                                    Visibility="{Binding Data.ColDayChange.IsVisible,
                                                         Source={StaticResource VMProxy},
                                                         Converter={StaticResource BoolToVisibility}}" />
                                <DataGridTextColumn Header="Change %"
                                    Binding="{Binding DayChangePctDisplay}"
                                    Width="74"
                                    Visibility="{Binding Data.ColDayChangePct.IsVisible,
                                                         Source={StaticResource VMProxy},
                                                         Converter={StaticResource BoolToVisibility}}" />

                                <!-- Technical -->
                                <DataGridTextColumn Header="RSI14"
                                    Binding="{Binding RSI14, StringFormat={}{0:F1}}"
                                    Width="58"
                                    Visibility="{Binding Data.ColRSI.IsVisible,
                                                         Source={StaticResource VMProxy},
                                                         Converter={StaticResource BoolToVisibility}}" />
                                <DataGridTextColumn Header="Wk Ret%"
                                    Binding="{Binding WeekReturnDisplay}"
                                    Width="68"
                                    Visibility="{Binding Data.ColWeekReturn.IsVisible,
                                                         Source={StaticResource VMProxy},
                                                         Converter={StaticResource BoolToVisibility}}" />
                                <DataGridTextColumn Header="SMA20"
                                    Binding="{Binding SMA20, StringFormat={}{0:F2}}"
                                    Width="68"
                                    Visibility="{Binding Data.ColSMA20.IsVisible,
                                                         Source={StaticResource VMProxy},
                                                         Converter={StaticResource BoolToVisibility}}" />
                                <DataGridTextColumn Header="SMA50"
                                    Binding="{Binding SMA50, StringFormat={}{0:F2}}"
                                    Width="68"
                                    Visibility="{Binding Data.ColSMA50.IsVisible,
                                                         Source={StaticResource VMProxy},
                                                         Converter={StaticResource BoolToVisibility}}" />
                                <DataGridTextColumn Header="Vol Trend"
                                    Binding="{Binding VolumeTrend, StringFormat={}{0:F2}}"
                                    Width="72"
                                    Visibility="{Binding Data.ColVolTrend.IsVisible,
                                                         Source={StaticResource VMProxy},
                                                         Converter={StaticResource BoolToVisibility}}" />

                                <!-- Confidence -->
                                <DataGridTextColumn Header="Conf."
                                    Binding="{Binding Confidence, StringFormat={}{0:P0}}"
                                    Width="58"
                                    Visibility="{Binding Data.ColConf.IsVisible,
                                                         Source={StaticResource VMProxy},
                                                         Converter={StaticResource BoolToVisibility}}" />

                                <!-- Trade dates -->
                                <DataGridTextColumn Header="Buy"
                                    Binding="{Binding BuyDate,  StringFormat={}{0:MMM d}}"
                                    Width="60"
                                    Visibility="{Binding Data.ColBuyDate.IsVisible,
                                                         Source={StaticResource VMProxy},
                                                         Converter={StaticResource BoolToVisibility}}" />
                                <DataGridTextColumn Header="Sell"
                                    Binding="{Binding SellDate, StringFormat={}{0:MMM d}}"
                                    Width="60"
                                    Visibility="{Binding Data.ColSellDate.IsVisible,
                                                         Source={StaticResource VMProxy},
                                                         Converter={StaticResource BoolToVisibility}}" />

                                <!-- Volume -->
                                <DataGridTextColumn Header="Volume"
                                    Binding="{Binding VolumeDisplay}"
                                    Width="72"
                                    Visibility="{Binding Data.ColVolume.IsVisible,
                                                         Source={StaticResource VMProxy},
                                                         Converter={StaticResource BoolToVisibility}}" />
                                <DataGridTextColumn Header="Avg Vol"
                                    Binding="{Binding AvgVolumeDisplay}"
                                    Width="72"
                                    Visibility="{Binding Data.ColAvgVolume.IsVisible,
                                                         Source={StaticResource VMProxy},
                                                         Converter={StaticResource BoolToVisibility}}" />

                                <!-- Valuation -->
                                <DataGridTextColumn Header="Mkt Cap"
                                    Binding="{Binding MarketCapDisplay}"
                                    Width="78"
                                    Visibility="{Binding Data.ColMarketCap.IsVisible,
                                                         Source={StaticResource VMProxy},
                                                         Converter={StaticResource BoolToVisibility}}" />
                                <DataGridTextColumn Header="P/E"
                                    Binding="{Binding PERatio, StringFormat={}{0:F1}}"
                                    Width="54"
                                    Visibility="{Binding Data.ColPE.IsVisible,
                                                         Source={StaticResource VMProxy},
                                                         Converter={StaticResource BoolToVisibility}}" />
                                <DataGridTextColumn Header="Fwd P/E"
                                    Binding="{Binding ForwardPE, StringFormat={}{0:F1}}"
                                    Width="64"
                                    Visibility="{Binding Data.ColForwardPE.IsVisible,
                                                         Source={StaticResource VMProxy},
                                                         Converter={StaticResource BoolToVisibility}}" />
                                <DataGridTextColumn Header="EPS"
                                    Binding="{Binding EPS, StringFormat={}{0:F2}}"
                                    Width="54"
                                    Visibility="{Binding Data.ColEPS.IsVisible,
                                                         Source={StaticResource VMProxy},
                                                         Converter={StaticResource BoolToVisibility}}" />
                                <DataGridTextColumn Header="P/B"
                                    Binding="{Binding PriceToBook, StringFormat={}{0:F2}}"
                                    Width="54"
                                    Visibility="{Binding Data.ColPriceToBook.IsVisible,
                                                         Source={StaticResource VMProxy},
                                                         Converter={StaticResource BoolToVisibility}}" />

                                <!-- Range & risk -->
                                <DataGridTextColumn Header="52W Hi"
                                    Binding="{Binding Week52High, StringFormat={}{0:F2}}"
                                    Width="68"
                                    Visibility="{Binding Data.Col52WkHigh.IsVisible,
                                                         Source={StaticResource VMProxy},
                                                         Converter={StaticResource BoolToVisibility}}" />
                                <DataGridTextColumn Header="52W Lo"
                                    Binding="{Binding Week52Low, StringFormat={}{0:F2}}"
                                    Width="68"
                                    Visibility="{Binding Data.Col52WkLow.IsVisible,
                                                         Source={StaticResource VMProxy},
                                                         Converter={StaticResource BoolToVisibility}}" />
                                <DataGridTextColumn Header="Beta"
                                    Binding="{Binding Beta, StringFormat={}{0:F2}}"
                                    Width="54"
                                    Visibility="{Binding Data.ColBeta.IsVisible,
                                                         Source={StaticResource VMProxy},
                                                         Converter={StaticResource BoolToVisibility}}" />
                                <DataGridTextColumn Header="Div%"
                                    Binding="{Binding DividendYieldPct, StringFormat={}{0:F2}}"
                                    Width="54"
                                    Visibility="{Binding Data.ColDivYield.IsVisible,
                                                         Source={StaticResource VMProxy},
                                                         Converter={StaticResource BoolToVisibility}}" />
                                <DataGridTextColumn Header="Short"
                                    Binding="{Binding ShortRatio, StringFormat={}{0:F1}}"
                                    Width="54"
                                    Visibility="{Binding Data.ColShortRatio.IsVisible,
                                                         Source={StaticResource VMProxy},
                                                         Converter={StaticResource BoolToVisibility}}" />

                                <DataGridTextColumn Header="IV%"
                                    Binding="{Binding ImpliedVolatilityPctDisplay}"
                                    Width="54"
                                    Visibility="{Binding Data.ColIV.IsVisible,
                                                         Source={StaticResource VMProxy},
                                                         Converter={StaticResource BoolToVisibility}}" />
                                <DataGridTextColumn Header="Theta"
                                    Binding="{Binding ThetaDisplay}"
                                    Width="58"
                                    Visibility="{Binding Data.ColTheta.IsVisible,
                                                         Source={StaticResource VMProxy},
                                                         Converter={StaticResource BoolToVisibility}}" />

                                <!-- Reasoning — star width, always last -->
                                <DataGridTextColumn Header="Reasoning"
                                    Binding="{Binding Reasoning}"
                                    Width="*"
                                    Visibility="{Binding Data.ColReasoning.IsVisible,
                                                         Source={StaticResource VMProxy},
                                                         Converter={StaticResource BoolToVisibility}}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>

                <!-- ===== Day Picks tab ===== -->
                <!-- ===== Day Picks tab ===== -->
                <TabItem Header="Daily Picks">
                    <DockPanel>

                        <!-- Sub-header: status + strategy selector -->
                        <Border DockPanel.Dock="Top"
                                Background="#F5F5F5" BorderBrush="#DDD"
                                BorderThickness="0,0,0,1" Padding="8,5">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <TextBlock Text="Strategy:" VerticalAlignment="Center"
                                               Foreground="#555" Margin="0,0,4,0" FontSize="11" />
                                    <ComboBox ItemsSource="{Binding DayPickStrategyOptions}"
                                              SelectedItem="{Binding SelectedDayPickStrategy}"
                                              Width="120" FontSize="11" />
                                    <TextBlock Text="Universe:" VerticalAlignment="Center"
                                               Foreground="#555" Margin="10,0,4,0" FontSize="11" />
                                    <ComboBox ItemsSource="{Binding DayPickUniverseSizeOptions}"
                                              SelectedItem="{Binding DayPickUniverseSize}"
                                              Width="60" FontSize="11"
                                              ToolTip="Max stocks passed to the pick engine (0 = all from last scan)" />
                                </StackPanel>
                                <TextBlock Text="{Binding DayPicksStatus}"
                                           VerticalAlignment="Center"
                                           Foreground="#555" FontStyle="Italic" />
                            </DockPanel>
                        </Border>

                        <!-- Action buttons -->
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="4">
                            <Button Content="Add to Watch"
                                    Command="{Binding AddDayPickToWatchCommand}"
                                    CommandParameter="{Binding SelectedItems, ElementName=DayPicksGridFull}"
                                    Padding="10,4" Margin="0,0,6,0"
                                    ToolTip="Track selected intraday pick(s) on your Watch list" />
                            <Button Content="Add to Positions"
                                    Command="{Binding AddDayPickToHeldCommand}"
                                    CommandParameter="{Binding SelectedItems, ElementName=DayPicksGridFull}"
                                    Padding="10,4" Margin="0,0,12,0"
                                    ToolTip="Record selected pick(s) as open positions" />
                            <Button Content="↺ Refresh"
                                    Command="{Binding ForceRefreshDayPicksCommand}"
                                    Padding="10,4" Margin="0,0,8,0"
                                    ToolTip="Bypass cache and regenerate picks from current data" />
                            <Button Content="🤖 Ask AI about picks"
                                    Command="{Binding AskAIAboutPicksCommand}"
                                    Padding="10,4"
                                    ToolTip="Build a batch analysis prompt for all current picks and open Claude" />
                        </StackPanel>

                        <!-- Disclaimer -->
                        <TextBlock DockPanel.Dock="Bottom"
                                   Text="&#x26A0; These are algorithmic signals only &#x2014; not financial advice. Day trading carries significant risk. Always use your own judgment."
                                   FontSize="10" Foreground="#999" Margin="6,4" TextWrapping="Wrap" />

                        <!-- Picks grid -->
                        <DataGrid x:Name="DayPicksGridFull"
                                  ItemsSource="{Binding DayPicks}"
                                  SelectedItem="{Binding SelectedDayPick}"
                                  SelectionMode="Extended"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  AlternatingRowBackground="#FAFAFA"
                                  HorizontalScrollBarVisibility="Auto"
                                  EnableColumnVirtualization="True">

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Direction}" Value="Long">
                                            <Setter Property="Background" Value="#E8F5E9" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Direction}" Value="Short">
                                            <Setter Property="Background" Value="#FFEBEE" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                    <Setter Property="ToolTip">
                                        <Setter.Value>
                                            <ToolTip MaxWidth="360">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Symbol}" FontWeight="Bold" FontSize="13" />
                                                    <TextBlock Text="{Binding CompanyName}" Foreground="#444" Margin="0,2,0,4" />
                                                    <Separator />
                                                    <TextBlock Text="{Binding TriggerReason}" TextWrapping="Wrap"
                                                               Margin="0,6,0,0" FontStyle="Italic" />
                                                    <Separator Margin="0,6" />
                                                    <TextBlock Text="{Binding GeneratedAt, StringFormat='Generated: {0:HH:mm}'}"
                                                               Foreground="#888" FontSize="10" />
                                                </StackPanel>
                                            </ToolTip>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Symbol" Width="110" SortMemberPath="Symbol">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="2,1">
                                                <TextBlock Text="{Binding Symbol}" FontWeight="SemiBold" FontSize="12" />
                                                <TextBlock Text="{Binding CompanyName}" FontSize="9" Foreground="#666"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Direction" Binding="{Binding DirectionDisplay}" Width="80" />
                                <DataGridTextColumn Header="Score" Binding="{Binding ScoreDisplay}" Width="56" SortMemberPath="IntraDayScore" />
                                <DataGridTextColumn Header="Conf." Binding="{Binding ConfidenceDisplay}" Width="58" SortMemberPath="Confidence" />
                                <DataGridTextColumn Header="Open" Binding="{Binding DayOpen, StringFormat={}{0:F2}}" Width="68" />
                                <DataGridTextColumn Header="Price" Binding="{Binding LastPrice, StringFormat={}{0:F2}}" Width="68" />
                                <DataGridTextColumn Header="Day Chg%" Binding="{Binding DayChangePctDisplay}" Width="72" />
                                <DataGridTextColumn Header="Vol Ratio" Binding="{Binding VolumeRatioDisplay}" Width="72" SortMemberPath="VolumeRatio" />
                                <DataGridTextColumn Header="Gap%" Binding="{Binding GapPctDisplay}" Width="60" SortMemberPath="GapPct" />
                                <DataGridTextColumn Header="ATR%" Binding="{Binding AtrPctDisplay}" Width="56" SortMemberPath="AtrPct" />
                                <DataGridTextColumn Header="RSI14" Binding="{Binding RSI14, StringFormat={}{0:F1}}" Width="52" />
                                <DataGridTextColumn Header="Entry" Binding="{Binding EntryPrice, StringFormat={}{0:F2}}" Width="64" />
                                <DataGridTextColumn Header="Stop" Binding="{Binding StopLoss, StringFormat={}{0:F2}}" Width="64" />
                                <DataGridTextColumn Header="Target" Binding="{Binding Target, StringFormat={}{0:F2}}" Width="64" />
                                <DataGridTextColumn Header="R:R" Binding="{Binding RiskRewardDisplay}" Width="50" SortMemberPath="RiskRewardRatio" />
                                <DataGridTextColumn Header="Signals" Binding="{Binding TriggerReason}" Width="*" MinWidth="260" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>

                <!-- ===== Earnings tab ===== -->
                <TabItem Header="Earnings">
                    <DockPanel>

                        <!-- Sub-header: window + target % + margin controls + status -->
                        <Border DockPanel.Dock="Top"
                                Background="#F5F5F5" BorderBrush="#DDD"
                                BorderThickness="0,0,0,1" Padding="8,5">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <TextBlock Text="Within:" VerticalAlignment="Center"
                                               Foreground="#555" Margin="0,0,4,0" FontSize="11" />
                                    <ComboBox ItemsSource="{Binding EarningsWindowOptions}"
                                              SelectedItem="{Binding EarningsWindowDays}"
                                              Width="56" FontSize="11"
                                              ToolTip="Show stocks with earnings within this many days" />
                                    <TextBlock Text="days" VerticalAlignment="Center"
                                               Foreground="#555" Margin="3,0,12,0" FontSize="11" />

                                    <TextBlock Text="Target ▲:" VerticalAlignment="Center"
                                               Foreground="#555" Margin="0,0,4,0" FontSize="11" />
                                    <TextBox Text="{Binding EarningsTargetUpPercent, StringFormat={}{0:0.#}, UpdateSourceTrigger=LostFocus}"
                                             Width="44" FontSize="11" VerticalContentAlignment="Center"
                                             ToolTip="Upside % the likelihood flag is measured against" />
                                    <TextBlock Text="%" VerticalAlignment="Center"
                                               Foreground="#555" Margin="2,0,12,0" FontSize="11" />

                                    <CheckBox Content="Buy on margin"
                                              IsChecked="{Binding EarningsUseMargin}"
                                              VerticalAlignment="Center" FontSize="11"
                                              ToolTip="Recompute returns assuming leverage and margin interest" />
                                    <Slider Minimum="10" Maximum="100"
                                            Value="{Binding EarningsMarginPercent}"
                                            Width="90" Margin="6,0,4,0" VerticalAlignment="Center"
                                            TickFrequency="5" IsSnapToTickEnabled="True"
                                            IsEnabled="{Binding EarningsUseMargin}"
                                            ToolTip="Equity margin requirement % (lower = more leverage)" />
                                    <TextBlock Text="{Binding EarningsLeverageDisplay}"
                                               VerticalAlignment="Center" FontSize="11"
                                               Foreground="#555" Margin="0,0,10,0" MinWidth="78" />
                                    <TextBlock Text="Rate:" VerticalAlignment="Center"
                                               Foreground="#555" Margin="0,0,4,0" FontSize="11" />
                                    <TextBox Text="{Binding EarningsMarginRatePct, StringFormat={}{0:0.##}, UpdateSourceTrigger=LostFocus}"
                                             Width="44" FontSize="11" VerticalContentAlignment="Center"
                                             IsEnabled="{Binding EarningsUseMargin}"
                                             ToolTip="Annualized margin interest rate %" />
                                    <TextBlock Text="%" VerticalAlignment="Center"
                                               Foreground="#555" Margin="2,0,0,0" FontSize="11" />
                                </StackPanel>
                                <TextBlock Text="{Binding EarningsStatus}"
                                           VerticalAlignment="Center"
                                           Foreground="#555" FontStyle="Italic" />
                            </DockPanel>
                        </Border>

                        <!-- Action buttons -->
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="4">
                            <Button Content="Add to Watch"
                                    Command="{Binding AddEarningsToWatchCommand}"
                                    CommandParameter="{Binding SelectedItems, ElementName=EarningsGridFull}"
                                    Padding="10,4" Margin="0,0,6,0"
                                    ToolTip="Track selected stock(s) on your Watch list" />
                            <Button Content="Add to Positions"
                                    Command="{Binding AddEarningsToHeldCommand}"
                                    CommandParameter="{Binding SelectedItems, ElementName=EarningsGridFull}"
                                    Padding="10,4" Margin="0,0,12,0"
                                    ToolTip="Record selected stock(s) as open positions" />
                            <Button Content="↺ Refresh"
                                    Command="{Binding ForceRefreshEarningsCommand}"
                                    Padding="10,4"
                                    ToolTip="Re-scan the universe for upcoming earnings" />
                        </StackPanel>

                        <!-- Disclaimer -->
                        <TextBlock DockPanel.Dock="Bottom"
                                   Text="&#x26A0; The likelihood score is a heuristic estimate from implied volatility and momentum &#x2014; NOT a prediction or financial advice. Earnings trades carry significant risk; margin amplifies both gains and losses."
                                   FontSize="10" Foreground="#999" Margin="6,4" TextWrapping="Wrap" />

                        <!-- Earnings grid -->
                        <DataGrid x:Name="EarningsGridFull"
                                  ItemsSource="{Binding EarningsPicks}"
                                  SelectedItem="{Binding SelectedEarningsPick}"
                                  SelectionMode="Extended"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  AlternatingRowBackground="#FAFAFA"
                                  HorizontalScrollBarVisibility="Auto"
                                  EnableColumnVirtualization="True">

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding MeetsThreshold}" Value="True">
                                            <Setter Property="Background" Value="#E8F5E9" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                    <Setter Property="ToolTip">
                                        <Setter.Value>
                                            <ToolTip MaxWidth="360">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Symbol}" FontWeight="Bold" FontSize="13" />
                                                    <TextBlock Text="{Binding CompanyName}" Foreground="#444" Margin="0,2,0,4" />
                                                    <Separator />
                                                    <TextBlock Text="{Binding TriggerReason}" TextWrapping="Wrap"
                                                               Margin="0,6,0,0" FontStyle="Italic" />
                                                    <Separator Margin="0,6" />
                                                    <TextBlock Text="{Binding GeneratedAt, StringFormat='Generated: {0:HH:mm}'}"
                                                               Foreground="#888" FontSize="10" />
                                                </StackPanel>
                                            </ToolTip>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Symbol" Width="110" SortMemberPath="Symbol">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="2,1">
                                                <TextBlock Text="{Binding Symbol}" FontWeight="SemiBold" FontSize="12" />
                                                <TextBlock Text="{Binding CompanyName}" FontSize="9" Foreground="#666"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Earnings" Binding="{Binding EarningsDateDisplay}" Width="120" SortMemberPath="NextEarningsDate" />
                                <DataGridTextColumn Header="Days" Binding="{Binding DaysUntilEarnings}" Width="50" SortMemberPath="DaysUntilEarnings" />
                                <DataGridTextColumn Header="Price" Binding="{Binding LastPrice, StringFormat={}{0:F2}}" Width="68" />
                                <DataGridTextColumn Header="Day Chg%" Binding="{Binding DayChangePctDisplay}" Width="72" />
                                <DataGridTextColumn Header="Impl. Move" Binding="{Binding ExpectedMoveDisplay}" Width="78" SortMemberPath="ExpectedMovePct" />
                                <DataGridTextColumn Header="Score" Binding="{Binding ScoreDisplay}" Width="56" SortMemberPath="LikelihoodScore" />
                                <DataGridTextColumn Header="Flag" Binding="{Binding FlagDisplay}" Width="80" SortMemberPath="MeetsThreshold" />
                                <DataGridTextColumn Header="Momentum" Binding="{Binding MomentumDisplay}" Width="78" SortMemberPath="MomentumPct" />
                                <DataGridTextColumn Header="Leverage" Binding="{Binding LeverageDisplay}" Width="68" SortMemberPath="Leverage" />
                                <DataGridTextColumn Header="Interest" Binding="{Binding InterestCostDisplay}" Width="66" SortMemberPath="InterestCostPct" />
                                <DataGridTextColumn Header="Net Ret%" Binding="{Binding NetMarginReturnDisplay}" Width="72" SortMemberPath="NetMarginReturnPct" />
                                <DataGridTextColumn Header="Signals" Binding="{Binding TriggerReason}" Width="*" MinWidth="260" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>

                <!-- ===== News tab ===== -->
                <TabItem Header="News">
                    <DockPanel>
                        <!-- Sub-header: status -->
                        <Border DockPanel.Dock="Top"
                                Background="#F5F5F5" BorderBrush="#DDD"
                                BorderThickness="0,0,0,1" Padding="8,5">
                            <TextBlock Text="{Binding NewsStatus}"
                                       VerticalAlignment="Center"
                                       Foreground="#555" FontStyle="Italic" />
                        </Border>

                        <!-- Action buttons -->
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="4">
                            <Button Content="📋 Copy briefing"
                                    Command="{Binding CopyNewsCommand}"
                                    Padding="10,4" Margin="0,0,6,0"
                                    ToolTip="Copy the full briefing to the clipboard for pasting into another LLM" />
                            <Button Content="💾 Save"
                                    Click="SaveNews_Click"
                                    Padding="10,4" Margin="0,0,6,0"
                                    ToolTip="Save the briefing to a Markdown/text file" />
                            <Button Content="↻ Regenerate"
                                    Command="{Binding RegenerateNewsCommand}"
                                    Padding="10,4" Margin="0,0,12,0"
                                    ToolTip="Rebuild the briefing from the current recommendations and settings" />
                            <Button Content="🤖 Open in Claude"
                                    Command="{Binding AskAINewsCommand}"
                                    Padding="10,4"
                                    ToolTip="Copy the briefing and open Claude in your browser" />
                        </StackPanel>

                        <!-- Disclaimer -->
                        <TextBlock DockPanel.Dock="Bottom"
                                   Text="&#x26A0; Algorithmic briefing only &#x2014; not financial advice. Intended as input for further LLM analysis; verify independently."
                                   FontSize="10" Foreground="#999" Margin="6,4" TextWrapping="Wrap" />

                        <!-- Briefing text (read-only, selectable) -->
                        <TextBox Text="{Binding NewsReport, Mode=OneWay}"
                                 IsReadOnly="True" IsReadOnlyCaretVisible="True"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas, Courier New" FontSize="12"
                                 Background="White" BorderThickness="0" Padding="8"
                                 VerticalContentAlignment="Top" />
                    </DockPanel>
                </TabItem>

                <!-- ===== Watch tab ===== -->
                <TabItem Header="{Binding WatchTabHeader}">
                    <Grid>
                        <!-- Empty-state overlay -->
                        <TextBlock Text="Your watch list is empty.&#x0A;Select a recommendation and click &#x22;Add to Watch&#x22;."
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   TextAlignment="Center" Foreground="#AAA" FontStyle="Italic"
                                   Visibility="{Binding WatchListIsEmpty, Converter={StaticResource BoolToVisibility}}" />

                        <DockPanel Visibility="{Binding WatchListIsEmpty, Converter={StaticResource InverseBoolToVisibility}}">
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="4">
                                <Button Content="Move to Positions"
                                        Command="{Binding PromoteWatchToPositionCommand}"
                                        Padding="10,4" Margin="0,0,6,0"
                                        ToolTip="Move this stock from Watch to your open Positions" />
                                <Button Content="Remove from Watch"
                                        Click="RemoveFromWatch_Click"
                                        Padding="10,4" Margin="0,0,12,0" />
                                <Button Content="↺ Refresh Prices"
                                        Command="{Binding RefreshWatchPricesCommand}"
                                        Padding="10,4"
                                        ToolTip="Fetch live prices for all watched stocks" />
                            </StackPanel>
                            <DataGrid x:Name="WatchGridFull"
                                      ItemsSource="{Binding WatchList}"
                                      SelectedItem="{Binding SelectedWatch}"
                                      SelectionMode="Extended"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      AlternatingRowBackground="#F7F7F7">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="ContextMenu" Value="{StaticResource RowContextMenu}" />
                                        <Setter Property="ToolTip">
                                            <Setter.Value>
                                                <ToolTip>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Symbol}" FontWeight="Bold" FontSize="13" />
                                                        <TextBlock Text="{Binding CompanyName}" Foreground="#444" Margin="0,2,0,6" />
                                                        <TextBlock Text="{Binding WatchedPrice, StringFormat='Added at: ${0:F2}'}" />
                                                        <TextBlock Text="{Binding WatchedAt, StringFormat='Date added: {0:MMM d, yyyy  HH:mm}'}" />
                                                        <TextBlock Text="{Binding LastPrice, StringFormat='Current price: ${0:F2}'}" Margin="0,4,0,0" />
                                                        <TextBlock Text="{Binding WatchChangePctDisplay, StringFormat='Change since watch: {0}'}" FontWeight="SemiBold" />
                                                    </StackPanel>
                                                </ToolTip>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WatchIsUp}" Value="True">
                                                <Setter Property="Background" Value="#E8F5E9" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding WatchIsUp}" Value="False">
                                                <Setter Property="Background" Value="#FFEBEE" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Symbol" Width="110" SortMemberPath="Symbol">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="2,1">
                                                    <TextBlock Text="{Binding Symbol}" FontWeight="SemiBold" FontSize="12" />
                                                    <TextBlock Text="{Binding CompanyName}" FontSize="9" Foreground="#666"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Action"    Binding="{Binding Action}"               Width="88" />
                                    <DataGridTextColumn Header="Added @"   Binding="{Binding WatchedPriceDisplay}"  Width="72" SortMemberPath="WatchedPrice" />
                                    <DataGridTextColumn Header="Added On"  Binding="{Binding WatchedAtDisplay}"     Width="72" SortMemberPath="WatchedAt" />
                                    <DataGridTextColumn Header="Now"       Binding="{Binding LastPrice, StringFormat={}{0:F2}}" Width="68" />
                                    <DataGridTextColumn Header="Chg Since" Binding="{Binding WatchChangePctDisplay}" Width="76" SortMemberPath="WatchChangePct" />
                                    <DataGridTextColumn Header="Day Chg%"  Binding="{Binding DayChangePctDisplay}"  Width="72" />
                                    <DataGridTextColumn Header="Buy"       Binding="{Binding BuyDate,  StringFormat={}{0:MMM d}}" Width="60" />
                                    <DataGridTextColumn Header="Sell"      Binding="{Binding SellDate, StringFormat={}{0:MMM d}}" Width="60" />
                                    <DataGridTextColumn Header="Source"    Binding="{Binding SourceTag}"  Width="88" />
                                    <DataGridTextColumn Header="Reasoning" Binding="{Binding Reasoning}" Width="*" MinWidth="220" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Grid>
                </TabItem>

                <!-- ===== Positions tab ===== -->
                <TabItem Header="{Binding PositionsTabHeader}">
                    <Grid>
                        <!-- Empty-state overlay -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding HeldListIsEmpty, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="No open positions yet.&#x0A;Add one manually, or use &#x22;Mark as Held&#x22; / &#x22;Move to Positions&#x22;."
                                       TextAlignment="Center" Foreground="#AAA" FontStyle="Italic" />
                            <Button Content="➕  Add Position" Click="AddPosition_Click"
                                    Padding="12,6" Margin="0,12,0,0" HorizontalAlignment="Center"
                                    ToolTip="Manually enter a position you hold" />
                        </StackPanel>

                        <DockPanel Visibility="{Binding HeldListIsEmpty, Converter={StaticResource InverseBoolToVisibility}}">
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="4">
                                <Button Content="➕ Add Position" Click="AddPosition_Click"
                                        Padding="10,4" Margin="0,0,6,0"
                                        ToolTip="Manually add a new position" />
                                <Button Content="✎ Edit" Click="EditPosition_Click"
                                        Padding="10,4" Margin="0,0,12,0"
                                        ToolTip="Edit the selected position (or double-click a row)" />
                                <Button Content="Remove from Positions"
                                        Click="RemoveFromPosition_Click"
                                        Padding="10,4" />
                            </StackPanel>

                            <!-- Performance panel: week / month / quarter / year -->
                            <Border DockPanel.Dock="Top" Background="#F5F7FA" BorderBrush="#DDE3EA"
                                    BorderThickness="0,0,0,1" Padding="8,6" Margin="0,0,0,2">
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="↻" Width="26" Height="24" Padding="0"
                                            VerticalAlignment="Top"
                                            Command="{Binding RefreshPerformanceCommand}"
                                            ToolTip="Recompute performance from the latest prices" />
                                    <TextBlock DockPanel.Dock="Right" Text="updating…" VerticalAlignment="Center"
                                               Margin="0,0,6,0" Foreground="#999" FontSize="10"
                                               Visibility="{Binding IsPerformanceLoading, Converter={StaticResource BoolToVisibility}}" />
                                    <StackPanel Orientation="Horizontal">
                                        <!-- Totals -->
                                        <StackPanel Margin="0,0,18,0" VerticalAlignment="Center">
                                            <TextBlock Text="Portfolio value" FontSize="10" Foreground="#789" />
                                            <TextBlock Text="{Binding Performance.MarketValueDisplay}" FontWeight="Bold" FontSize="15" />
                                            <TextBlock FontSize="11">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#388E3C" />
                                                        <Setter Property="Text" Value="{Binding Performance.TotalGainPctDisplay}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Performance.IsUp}" Value="False">
                                                                <Setter Property="Foreground" Value="#D32F2F" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <!-- Trailing-window cards -->
                                        <ItemsControl ItemsSource="{Binding Performance.Periods}" VerticalAlignment="Center">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,8,0" Padding="9,3" Background="White"
                                                            BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" MinWidth="78">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Label}" FontSize="10" Foreground="#789" />
                                                            <TextBlock FontWeight="Bold" FontSize="13">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#388E3C" />
                                                                        <Setter Property="Text" Value="{Binding PctDisplay}" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsUp}" Value="False">
                                                                                <Setter Property="Foreground" Value="#D32F2F" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding HasData}" Value="False">
                                                                                <Setter Property="Foreground" Value="#AAA" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <TextBlock Text="{Binding AmountDisplay}" FontSize="10" Foreground="#888" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DockPanel>
                            </Border>

                            <DataGrid ItemsSource="{Binding HeldList}"
                                      SelectedItem="{Binding SelectedHeld}"
                                      MouseDoubleClick="HeldGrid_DoubleClick"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      AlternatingRowBackground="#F7F7F7">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="ContextMenu" Value="{StaticResource RowContextMenu}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsProfit}" Value="True">
                                                <Setter Property="Background" Value="#E8F5E9" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsProfit}" Value="False">
                                                <Setter Property="Background" Value="#FFEBEE" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Symbol" Width="110" SortMemberPath="Symbol">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="2,1">
                                                    <TextBlock Text="{Binding Symbol}" FontWeight="SemiBold" FontSize="12" />
                                                    <TextBlock Text="{Binding CompanyName}" FontSize="9" Foreground="#666"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Source"       Binding="{Binding SourceTag}"                                    Width="100" />
                                    <DataGridTextColumn Header="Entry Date"   Binding="{Binding EntryDate, StringFormat={}{0:MMM d}}"        Width="76" />
                                    <DataGridTextColumn Header="Target Exit"  Binding="{Binding PlannedSellDate, StringFormat={}{0:MMM d}}"  Width="76" />
                                    <DataGridTextColumn Header="Entry $"      Binding="{Binding EntryPrice, StringFormat={}{0:C}}"           Width="76" />
                                    <DataGridTextColumn Header="Shares"       Binding="{Binding ShareCount}"                                  Width="56" />
                                    <DataGridTextColumn Header="Current $"    Binding="{Binding CurrentValueDisplay}"                         Width="80" />
                                    <DataGridTextColumn Header="Gain $"       Binding="{Binding UnrealizedGainDisplay}"                      Width="76" />
                                    <DataGridTextColumn Header="Gain %"       Binding="{Binding UnrealizedGainPctDisplay}"                   Width="68" />
                                    <DataGridTextColumn Header="Hold"         Binding="{Binding HoldingPeriod}"                               Width="64" />
                                    <DataGridTextColumn Header="Notes"        Binding="{Binding Notes}"                                       Width="*" MinWidth="220" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Grid>
                </TabItem>
            </TabControl>

            <GridSplitter Grid.Column="1" Width="4"
                          HorizontalAlignment="Stretch"
                          Background="#DDDDDD"
                          ToolTip="Drag to resize"
                          Visibility="{Binding ShowDetails, Converter={StaticResource BoolToVisibility}}" />

            <GroupBox Grid.Column="2"
                      Header="{Binding ActiveSelection.Symbol, StringFormat='Details — {0}', FallbackValue='Details'}"
                      Visibility="{Binding ShowDetails, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <!-- Empty-state hint -->
                    <TextBlock Text="Select a stock to see details."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#AAA" FontStyle="Italic"
                               Visibility="{Binding HasActiveSelection, Converter={StaticResource InverseBoolToVisibility}}" />
                    <DockPanel Visibility="{Binding HasActiveSelection, Converter={StaticResource BoolToVisibility}}">
                        <!-- Weekly chart + range toggle -->
                        <Grid DockPanel.Dock="Top" Height="130" Margin="0,0,0,4">
                            <ctrl:StockChartControl
                                Bars="{Binding DataContext.WeeklyBars, RelativeSource={RelativeSource AncestorType=Window}}"
                                IsLoading="{Binding DataContext.IsChartLoading, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                        VerticalAlignment="Top" Margin="0,4,6,0">
                                <RadioButton Content="1Y" GroupName="ChartRangeFull"
                                             Style="{StaticResource ChartRangeBtn}"
                                             Margin="0,0,3,0"
                                             IsChecked="{Binding DataContext.IsChartYear, RelativeSource={RelativeSource AncestorType=Window}}" />
                                <RadioButton Content="1W" GroupName="ChartRangeFull"
                                             Style="{StaticResource ChartRangeBtn}"
                                             IsChecked="{Binding DataContext.IsChartWeek, RelativeSource={RelativeSource AncestorType=Window}}" />
                            </StackPanel>
                        </Grid>
                        <!-- Fundamental / technical stats -->
                        <!-- No explicit ContentTemplate: WPF picks the implicit
                             DataTemplate that matches ActiveSelection's runtime type. -->
                        <ContentControl Content="{Binding ActiveSelection}" />
                    </DockPanel>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- COMPACT LAYOUT -->
        <Grid Grid.Row="2"
              Visibility="{Binding LayoutMode,
                          Converter={StaticResource LayoutModeToVisibility},
                          ConverterParameter=Compact}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"    MinHeight="160" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="2*"   MinHeight="160" />
            </Grid.RowDefinitions>

            <!-- ── Top pane: tabs ── -->
            <TabControl Grid.Row="0" Style="{StaticResource ScrollableHeaderTabControl}">

                <!-- Recommendations -->
                <TabItem Header="Recommendations">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="4">
                            <Button Content="Watch" Command="{Binding AddToWatchCommand}"
                                    Padding="8,4" Margin="0,0,4,0" />
                            <Button Content="Held"  Command="{Binding AddToHeldCommand}" Padding="8,4" />
                        </StackPanel>
                        <!-- Filter bar (compact) -->
                        <Border DockPanel.Dock="Top" Background="#F5F5F5" BorderBrush="#DDD"
                                BorderThickness="0,0,0,1" Padding="4,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" BorderBrush="#CCC" BorderThickness="1"
                                        CornerRadius="3" Background="White" Margin="0,0,6,0">
                                    <Grid>
                                        <TextBlock Text="Search symbol or company…"
                                                   Foreground="#AAA" FontSize="10" Margin="4,3"
                                                   IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 BorderThickness="0" Background="Transparent"
                                                 VerticalContentAlignment="Center" Padding="4,2"
                                                 FontSize="11" />
                                    </Grid>
                                </Border>
                                <ToggleButton Grid.Column="1" Content="Buy Only"
                                              IsChecked="{Binding BuyOnlyFilter}"
                                              Padding="6,3" FontSize="11"
                                              ToolTip="Show only Buy-rated recommendations" />
                            </Grid>
                        </Border>

                        <DataGrid ItemsSource="{Binding RecommendationsView}"
                                  SelectedItem="{Binding SelectedRecommendation}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  RowStyle="{StaticResource RecRowStyle}">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Symbol" Width="80" SortMemberPath="Symbol">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="2,1">
                                                <TextBlock Text="{Binding Symbol}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding CompanyName}" FontSize="9" Foreground="#666"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Act"     Binding="{Binding Action}"                           Width="78" SortMemberPath="ActionSortOrder" />
                                <DataGridTextColumn Header="$"       Binding="{Binding LastPrice, StringFormat={}{0:F2}}" Width="60" />
                                <DataGridTextColumn Header="Chg%"    Binding="{Binding DayChangePctDisplay}"              Width="64" />
                                <DataGridTextColumn Header="RSI"     Binding="{Binding RSI14, StringFormat={}{0:F1}}"     Width="50" />
                                <DataGridTextColumn Header="Buy"     Binding="{Binding BuyDate,  StringFormat={}{0:MMM d}}" Width="56" />
                                <DataGridTextColumn Header="Sell"    Binding="{Binding SellDate, StringFormat={}{0:MMM d}}" Width="56" />
                                <DataGridTextColumn Header="Conf."   Binding="{Binding Confidence, StringFormat={}{0:P0}}" Width="52" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>

                <!-- Daily Picks -->
                <TabItem Header="Daily Picks">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#F5F5F5" BorderBrush="#DDD"
                                BorderThickness="0,0,0,1" Padding="6,4">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <ComboBox ItemsSource="{Binding DayPickStrategyOptions}"
                                              SelectedItem="{Binding SelectedDayPickStrategy}"
                                              Width="110" FontSize="10" />
                                    <ComboBox ItemsSource="{Binding DayPickUniverseSizeOptions}"
                                              SelectedItem="{Binding DayPickUniverseSize}"
                                              Width="50" FontSize="10" Margin="4,0,0,0"
                                              ToolTip="Daily Picks universe cap (0=all)" />
                                </StackPanel>
                                <TextBlock Text="{Binding DayPicksStatus}"
                                           VerticalAlignment="Center" Foreground="#555" FontStyle="Italic" FontSize="10" />
                            </DockPanel>
                        </Border>
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="4">
                            <Button Content="Watch"
                                    Command="{Binding AddDayPickToWatchCommand}"
                                    CommandParameter="{Binding SelectedItems, ElementName=DayPicksGridCompact}"
                                    Padding="8,4" Margin="0,0,4,0" />
                            <Button Content="Position"
                                    Command="{Binding AddDayPickToHeldCommand}"
                                    CommandParameter="{Binding SelectedItems, ElementName=DayPicksGridCompact}"
                                    Padding="8,4" Margin="0,0,6,0" />
                            <Button Content="↺"
                                    Command="{Binding ForceRefreshDayPicksCommand}"
                                    Padding="6,4" Margin="0,0,4,0"
                                    ToolTip="Force refresh picks" />
                            <Button Content="🤖 Ask AI"
                                    Command="{Binding AskAIAboutPicksCommand}"
                                    Padding="6,4"
                                    ToolTip="Batch AI analysis of all current picks" />
                        </StackPanel>
                        <DataGrid x:Name="DayPicksGridCompact"
                                  ItemsSource="{Binding DayPicks}"
                                  SelectedItem="{Binding SelectedDayPick}"
                                  SelectionMode="Extended"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  AlternatingRowBackground="#FAFAFA">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Direction}" Value="Long">
                                            <Setter Property="Background" Value="#E8F5E9" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Direction}" Value="Short">
                                            <Setter Property="Background" Value="#FFEBEE" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}"              Width="64" />
                                <DataGridTextColumn Header="Dir"    Binding="{Binding DirectionDisplay}"    Width="50" />
                                <DataGridTextColumn Header="Score"  Binding="{Binding ScoreDisplay}"        Width="50" SortMemberPath="IntraDayScore" />
                                <DataGridTextColumn Header="Conf"   Binding="{Binding ConfidenceDisplay}"   Width="54" SortMemberPath="Confidence" />
                                <DataGridTextColumn Header="Open"   Binding="{Binding DayOpen, StringFormat={}{0:F2}}" Width="60" />
                                <DataGridTextColumn Header="$"      Binding="{Binding LastPrice, StringFormat={}{0:F2}}" Width="60" />
                                <DataGridTextColumn Header="Chg%"   Binding="{Binding DayChangePctDisplay}" Width="60" />
                                <DataGridTextColumn Header="R:R"    Binding="{Binding RiskRewardDisplay}"   Width="48" SortMemberPath="RiskRewardRatio" />
                                <DataGridTextColumn Header="Signals" Binding="{Binding TriggerReason}"      Width="*" MinWidth="220" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>

                <!-- Earnings -->
                <TabItem Header="Earnings">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#F5F5F5" BorderBrush="#DDD"
                                BorderThickness="0,0,0,1" Padding="6,4">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <ComboBox ItemsSource="{Binding EarningsWindowOptions}"
                                              SelectedItem="{Binding EarningsWindowDays}"
                                              Width="50" FontSize="10"
                                              ToolTip="Earnings within N days" />
                                    <TextBlock Text="▲" VerticalAlignment="Center" Foreground="#555" Margin="6,0,2,0" FontSize="10" />
                                    <TextBox Text="{Binding EarningsTargetUpPercent, StringFormat={}{0:0.#}, UpdateSourceTrigger=LostFocus}"
                                             Width="36" FontSize="10" VerticalContentAlignment="Center"
                                             ToolTip="Target upside %" />
                                    <CheckBox Content="Margin" IsChecked="{Binding EarningsUseMargin}"
                                              VerticalAlignment="Center" FontSize="10" Margin="6,0,0,0"
                                              ToolTip="Buy on margin (12.5% default rate)" />
                                    <Slider Minimum="10" Maximum="100" Value="{Binding EarningsMarginPercent}"
                                            Width="70" Margin="4,0,0,0" VerticalAlignment="Center"
                                            TickFrequency="5" IsSnapToTickEnabled="True"
                                            IsEnabled="{Binding EarningsUseMargin}"
                                            ToolTip="Margin requirement % (lower = more leverage)" />
                                </StackPanel>
                                <TextBlock Text="{Binding EarningsStatus}"
                                           VerticalAlignment="Center" Foreground="#555" FontStyle="Italic" FontSize="10" />
                            </DockPanel>
                        </Border>
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="4">
                            <Button Content="Watch"
                                    Command="{Binding AddEarningsToWatchCommand}"
                                    CommandParameter="{Binding SelectedItems, ElementName=EarningsGridCompact}"
                                    Padding="8,4" Margin="0,0,4,0" />
                            <Button Content="Position"
                                    Command="{Binding AddEarningsToHeldCommand}"
                                    CommandParameter="{Binding SelectedItems, ElementName=EarningsGridCompact}"
                                    Padding="8,4" Margin="0,0,6,0" />
                            <Button Content="↺"
                                    Command="{Binding ForceRefreshEarningsCommand}"
                                    Padding="6,4"
                                    ToolTip="Re-scan for upcoming earnings" />
                        </StackPanel>
                        <DataGrid x:Name="EarningsGridCompact"
                                  ItemsSource="{Binding EarningsPicks}"
                                  SelectedItem="{Binding SelectedEarningsPick}"
                                  SelectionMode="Extended"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  AlternatingRowBackground="#FAFAFA">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding MeetsThreshold}" Value="True">
                                            <Setter Property="Background" Value="#E8F5E9" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Symbol"  Binding="{Binding Symbol}"               Width="64" />
                                <DataGridTextColumn Header="Earnings" Binding="{Binding EarningsDateDisplay}"  Width="106" SortMemberPath="NextEarningsDate" />
                                <DataGridTextColumn Header="Move"    Binding="{Binding ExpectedMoveDisplay}"   Width="64" SortMemberPath="ExpectedMovePct" />
                                <DataGridTextColumn Header="Score"   Binding="{Binding ScoreDisplay}"          Width="50" SortMemberPath="LikelihoodScore" />
                                <DataGridTextColumn Header="Flag"    Binding="{Binding FlagDisplay}"           Width="72" SortMemberPath="MeetsThreshold" />
                                <DataGridTextColumn Header="Net%"    Binding="{Binding NetMarginReturnDisplay}" Width="60" SortMemberPath="NetMarginReturnPct" />
                                <DataGridTextColumn Header="Signals" Binding="{Binding TriggerReason}"         Width="*" MinWidth="220" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>

                <!-- News -->
                <TabItem Header="News">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#F5F5F5" BorderBrush="#DDD"
                                BorderThickness="0,0,0,1" Padding="6,4">
                            <TextBlock Text="{Binding NewsStatus}"
                                       VerticalAlignment="Center" Foreground="#555" FontStyle="Italic" FontSize="10" />
                        </Border>
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="4">
                            <Button Content="📋 Copy"
                                    Command="{Binding CopyNewsCommand}"
                                    Padding="8,4" Margin="0,0,4,0" />
                            <Button Content="💾 Save"
                                    Click="SaveNews_Click"
                                    Padding="8,4" Margin="0,0,4,0"
                                    ToolTip="Save the briefing to a file" />
                            <Button Content="↻"
                                    Command="{Binding RegenerateNewsCommand}"
                                    Padding="6,4" Margin="0,0,6,0"
                                    ToolTip="Regenerate briefing" />
                            <Button Content="🤖 Claude"
                                    Command="{Binding AskAINewsCommand}"
                                    Padding="6,4"
                                    ToolTip="Copy briefing and open Claude" />
                        </StackPanel>
                        <TextBox Text="{Binding NewsReport, Mode=OneWay}"
                                 IsReadOnly="True" IsReadOnlyCaretVisible="True"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas, Courier New" FontSize="11"
                                 Background="White" BorderThickness="0" Padding="6"
                                 VerticalContentAlignment="Top" />
                    </DockPanel>
                </TabItem>

                <!-- Watch -->
                <TabItem Header="{Binding WatchTabHeader}">
                    <Grid>
                        <TextBlock Text="Your watch list is empty."
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#AAA" FontStyle="Italic"
                                   Visibility="{Binding WatchListIsEmpty, Converter={StaticResource BoolToVisibility}}" />
                        <DockPanel Visibility="{Binding WatchListIsEmpty, Converter={StaticResource InverseBoolToVisibility}}">
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="4">
                                <Button Content="Move to Positions"
                                        Command="{Binding PromoteWatchToPositionCommand}"
                                        Padding="8,4" Margin="0,0,4,0" />
                                <Button Content="Remove"
                                        Click="RemoveFromWatch_Click"
                                        Padding="8,4" Margin="0,0,8,0" />
                                <Button Content="↺ Refresh"
                                        Command="{Binding RefreshWatchPricesCommand}"
                                        Padding="8,4"
                                        ToolTip="Fetch live prices for all watched stocks" />
                            </StackPanel>
                            <DataGrid x:Name="WatchGridCompact"
                                      ItemsSource="{Binding WatchList}"
                                      SelectedItem="{Binding SelectedWatch}"
                                      SelectionMode="Extended"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      AlternatingRowBackground="#F7F7F7">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="ContextMenu" Value="{StaticResource RowContextMenu}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WatchIsUp}" Value="True">
                                                <Setter Property="Background" Value="#E8F5E9" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding WatchIsUp}" Value="False">
                                                <Setter Property="Background" Value="#FFEBEE" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Symbol"    Binding="{Binding Symbol}"               Width="64" />
                                    <DataGridTextColumn Header="Added @"   Binding="{Binding WatchedPriceDisplay}"  Width="68" SortMemberPath="WatchedPrice" />
                                    <DataGridTextColumn Header="Now"       Binding="{Binding LastPrice, StringFormat={}{0:F2}}" Width="60" />
                                    <DataGridTextColumn Header="Chg"       Binding="{Binding WatchChangePctDisplay}" Width="68" SortMemberPath="WatchChangePct" />
                                    <DataGridTextColumn Header="Day%"      Binding="{Binding DayChangePctDisplay}"  Width="60" />
                                    <DataGridTextColumn Header="Action"    Binding="{Binding Action}"               Width="80" />
                                    <DataGridTextColumn Header="Source"    Binding="{Binding SourceTag}"              Width="88" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Grid>
                </TabItem>

                <!-- Positions -->
                <TabItem Header="{Binding PositionsTabHeader}">
                    <Grid>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding HeldListIsEmpty, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="No open positions yet." TextAlignment="Center"
                                       Foreground="#AAA" FontStyle="Italic" />
                            <Button Content="➕ Add Position" Click="AddPosition_Click"
                                    Padding="10,5" Margin="0,10,0,0" HorizontalAlignment="Center" />
                        </StackPanel>
                        <DockPanel Visibility="{Binding HeldListIsEmpty, Converter={StaticResource InverseBoolToVisibility}}">
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="4">
                                <Button Content="➕ Add" Click="AddPosition_Click" Padding="8,4" Margin="0,0,4,0" />
                                <Button Content="✎ Edit" Click="EditPosition_Click" Padding="8,4" Margin="0,0,8,0"
                                        ToolTip="Edit the selected position (or double-click a row)" />
                                <Button Content="Remove"
                                        Click="RemoveFromPosition_Click"
                                        Padding="8,4" />
                            </StackPanel>

                            <!-- Performance strip: week / month / quarter / year -->
                            <Border DockPanel.Dock="Top" Background="#F5F7FA" BorderBrush="#DDE3EA"
                                    BorderThickness="0,0,0,1" Padding="6,4" Margin="0,0,0,2">
                                <WrapPanel Orientation="Horizontal">
                                    <StackPanel Margin="0,0,12,0" VerticalAlignment="Center">
                                        <TextBlock Text="Value" FontSize="9" Foreground="#789" />
                                        <TextBlock Text="{Binding Performance.MarketValueDisplay}" FontWeight="Bold" FontSize="12" />
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{Binding Performance.Periods}" VerticalAlignment="Center">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,6,0" Padding="6,2" Background="White"
                                                        BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="3" MinWidth="58">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Label}" FontSize="9" Foreground="#789" />
                                                        <TextBlock FontWeight="Bold" FontSize="11">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#388E3C" />
                                                                    <Setter Property="Text" Value="{Binding PctDisplay}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsUp}" Value="False">
                                                                            <Setter Property="Foreground" Value="#D32F2F" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding HasData}" Value="False">
                                                                            <Setter Property="Foreground" Value="#AAA" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </WrapPanel>
                            </Border>

                            <DataGrid ItemsSource="{Binding HeldList}"
                                      SelectedItem="{Binding SelectedHeld}"
                                      MouseDoubleClick="HeldGrid_DoubleClick"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      AlternatingRowBackground="#F7F7F7">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="ContextMenu" Value="{StaticResource RowContextMenu}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsProfit}" Value="True">
                                                <Setter Property="Background" Value="#E8F5E9" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsProfit}" Value="False">
                                                <Setter Property="Background" Value="#FFEBEE" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Symbol"  Binding="{Binding Symbol}"                         Width="64" />
                                    <DataGridTextColumn Header="Source"  Binding="{Binding SourceTag}"                           Width="80" />
                                    <DataGridTextColumn Header="Entry"   Binding="{Binding EntryDate, StringFormat={}{0:MMM d}}" Width="56" />
                                    <DataGridTextColumn Header="Exit"    Binding="{Binding PlannedSellDate, StringFormat={}{0:MMM d}}" Width="56" />
                                    <DataGridTextColumn Header="Entry $" Binding="{Binding EntryPrice, StringFormat={}{0:C}}"           Width="68" />
                                    <DataGridTextColumn Header="Gain%"   Binding="{Binding UnrealizedGainPctDisplay}"                   Width="60" />
                                    <DataGridTextColumn Header="Hold"    Binding="{Binding HoldingPeriod}"                               Width="56" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Grid>
                </TabItem>
            </TabControl>

            <!-- Compact details pane splitter + panel -->
            <GridSplitter Grid.Row="1" Height="4"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          Background="#DDDDDD"
                          ToolTip="Drag to resize"
                          Visibility="{Binding ShowDetails, Converter={StaticResource BoolToVisibility}}" />

            <GroupBox Grid.Row="2"
                      Header="{Binding ActiveSelection.Symbol, StringFormat='Details — {0}', FallbackValue='Details'}"
                      Visibility="{Binding ShowDetails, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <TextBlock Text="Select a stock to see details."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#AAA" FontStyle="Italic"
                               Visibility="{Binding HasActiveSelection, Converter={StaticResource InverseBoolToVisibility}}" />
                    <DockPanel Visibility="{Binding HasActiveSelection, Converter={StaticResource BoolToVisibility}}">
                        <!-- No explicit ContentTemplate: WPF picks the implicit
                             DataTemplate that matches ActiveSelection's runtime type. -->
                        <ContentControl Content="{Binding ActiveSelection}" />
                    </DockPanel>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</Window>
